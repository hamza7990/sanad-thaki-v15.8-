NODE_ENV=production
APP_PORT=3000

# يجب تغييرها قبل أي تشغيل خارجي
JWT_SECRET=CHANGE_ME_64_CHARS_MINIMUM_RANDOM_VALUE_CHANGE_ME_64_CHARS
REFRESH_TOKEN_SECRET=CHANGE_ME_64_CHARS_MINIMUM_RANDOM_VALUE_REFRESH_CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# قاعدة البيانات داخل Docker
DATABASE_URL=postgresql://sanad_app:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/sanad_thaki

# ممنوع تفعيل الديمو في الإنتاج
ALLOW_DEMO_LOGIN=false
ACCESS_TOKEN_EXPIRES_IN=8h
DEMO_ADMIN_EMAIL=admin@sanad.local
DEMO_ADMIN_PASSWORD=ChangeMe123!Secure

# أدمن سند ذكي / مشغل المنصة - للتشغيل على Staging فقط ثم يغيّر فورًا
PLATFORM_ADMIN_EMAIL=platform-admin@sanad.local
PLATFORM_ADMIN_PASSWORD=ChangeMe123!Secure

# غيّرها لدومين Staging/Production لاحقًا
CORS_ORIGIN=http://localhost,http://127.0.0.1

# مفاتيح خارجية — لا تكتبها داخل الكود ولا GitHub
OPENAI_API_KEY=
OPENAI_INVOICE_MODEL=gpt-4o-mini
GOOGLE_DOCUMENT_AI_PROCESSOR_NAME=
GOOGLE_DOCUMENT_AI_API_ENDPOINT=
GOOGLE_APPLICATION_CREDENTIALS=
WHATSAPP_MODE=disabled
# Comma-separated allowed BSP API hosts, e.g. api.your-bsp.com. Required in production for BSP endpoints.
WHATSAPP_BSP_ALLOWED_HOSTS=
AWS_REGION=me-south-1
S3_BUCKET=

# Optional SMTP for production employee invitations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sanad.example.com


# v14.2.9 Database-per-Tenant Isolation
REQUIRE_DATABASE_PER_TENANT=true
TENANT_DATABASE_URLS_JSON={"company-EXAMPLE0001":"postgres://tenant_user:strong_password@tenant-db-host:5432/sanad_company_example"}
TENANT_DB_POOL_MAX=5
REQUIRE_TENANT_KMS=true
TENANT_KMS_KEYS_JSON={"company-EXAMPLE0001":"replace-with-tenant-specific-64-plus-character-secret-or-kms-alias"}
# DEFAULT_TENANT_KMS_KEY is forbidden in production. Use TENANT_KMS_KEYS_JSON only.


# v14.2.13 Salla Integration
# يستخدم لعرض رابط Webhook الصحيح عند حفظ إعدادات الربط داخل لوحة الشركة
PUBLIC_APP_URL=https://your-domain.example
# يفضل حفظ Salla webhook secret/access token من واجهة /integrations/salla/config لكل شركة.
# يمكن استخدام هذه الخرائط فقط كمرجع تشغيلي للمبرمج عند الحاجة، ولا ترفعها إلى Git.
SALLA_WEBHOOK_SECRETS_JSON={}
SALLA_ACCESS_TOKENS_JSON={}

# v14.3.0 Webhook / File Security Hardening
WEBHOOK_MAX_SKEW_SECONDS=300
# Bank statement upload is intentionally capped in code at 2MB / 5000 rows / 30 columns.

# v14.3.1 Production Readiness Security Lock
ENFORCE_HTTPS=true
RATE_LIMIT_GLOBAL_PER_MINUTE=180
RATE_LIMIT_LOGIN_PER_15_MIN=10
RATE_LIMIT_WEBHOOK_PER_MINUTE=30
RATE_LIMIT_BANK_UPLOAD_PER_MINUTE=5
# Production proxy/load-balancer must forward X-Forwarded-Proto=https.

# v14.3.6 Database-per-Tenant provisioning
# DATABASE_URL remains the Control DB URL.
PROVISIONER_DATABASE_URL=
TENANT_DATABASE_URL_TEMPLATE=
SECRETS_PROVIDER=local
LOCAL_TENANT_SECRET_DIR=.tenant-secrets
WEBHOOK_REQUIRE_TIMESTAMP=false
STRICT_CSP=false
REDIS_URL=

# Security Closure v15.4
SETUP_BOOTSTRAP_TOKEN=REPLACE_WITH_32_PLUS_RANDOM_BOOTSTRAP_TOKEN
INTERNAL_HEALTH_BEARER_TOKEN=REPLACE_WITH_STRONG_INTERNAL_HEALTH_TOKEN
RETURN_BEARER_TOKEN_IN_LOGIN=false
INTEGRATION_KEY_RATE_LIMIT_PER_MINUTE=60
REQUIRE_SECRETS_MANAGER_SMOKE_TEST=false
PROVISIONING_CLEAN_ORPHANS_CONFIRM=
PROVISIONING_ORPHAN_BACKUP_CONFIRMED=false
